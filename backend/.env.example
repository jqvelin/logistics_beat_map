# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/logistics_beat_map?schema=public"

# Required — JWT signing (must match across restarts)
JWT_SECRET="change-me-to-a-long-random-string"

# Optional — access token lifetime (default: 7d)
# JWT_EXPIRES_IN=7d

# Optional — HTTP listen port (default: 6767)
# PORT=6767

# Required — Resend API (email codes); app fails at startup if missing
RESEND_API_KEY="re_xxxxxxxx"

# Optional — verified sender in Resend (default: Logistics Beat Map <onboarding@resend.dev>)
# RESEND_FROM_EMAIL="Your App <verified@yourdomain.com>"
